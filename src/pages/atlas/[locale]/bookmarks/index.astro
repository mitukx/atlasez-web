---
/** あとで読む（ブックマーク）一覧。localStorageからクライアント側で描画する */
import AtlasLayout from "../../../../layouts/AtlasLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import { atlasPath } from "../../../../lib/site";
import { t, LOCALES, type Locale } from "../../../../lib/i18n";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
---

<AtlasLayout
  locale={locale}
  title={t(locale, "bookmarks")}
  description={t(locale, "bookmarksHint")}
  noindex={true}
  localeSwitchHrefs={Object.fromEntries(
    LOCALES.map((l) => [l, atlasPath(l, "bookmarks")]),
  )}
>
  <div class="container">
    <Breadcrumb
      items={[
        { label: t(locale, "breadcrumbHome"), href: atlasPath(locale) },
        { label: t(locale, "bookmarks") },
      ]}
    />
    <div class="bookmarks-head">
      <h1>{t(locale, "bookmarks")}</h1>
      <button
        type="button"
        class="button button-secondary"
        data-bookmark-clear
        hidden
      >
        {t(locale, "clearBookmarks")}
      </button>
    </div>
    <p class="bookmarks-hint">{t(locale, "bookmarksHint")}</p>

    <p
      class="bookmarks-empty"
      data-bookmark-empty
      data-remove-label={t(locale, "removeBookmark")}
    >
      {t(locale, "noBookmarks")}
    </p>
    <ol class="bookmarks-list" data-bookmark-list></ol>
  </div>
</AtlasLayout>

<style>
  .bookmarks-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }
  .bookmarks-hint {
    color: var(--text-secondary);
    font-size: calc(0.9rem * var(--text-scale));
  }
  .bookmarks-list {
    list-style: none;
    margin: var(--space-4) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: var(--content-width);
  }
  .bookmarks-list li {
    border: 1px solid var(--border);
    border-radius: var(--radius, 4px);
    padding: var(--space-3);
  }
  .bookmark-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
    align-items: baseline;
  }
  .bookmark-title {
    font-size: calc(1.05rem * var(--text-scale));
    font-weight: 600;
  }
  .bookmark-meta {
    color: var(--text-secondary);
    font-size: calc(0.82rem * var(--text-scale));
    margin: var(--space-1) 0 0;
  }
  .bookmark-summary {
    color: var(--text-secondary);
    font-size: calc(0.9rem * var(--text-scale));
    margin: var(--space-2) 0 0;
  }
  .bookmark-remove {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    border-radius: var(--radius, 4px);
    background: transparent;
    color: var(--text-secondary);
    font: inherit;
    font-size: calc(0.82rem * var(--text-scale));
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
  }
  .bookmark-remove:hover {
    color: var(--accent-primary);
    border-color: var(--accent-primary);
  }
</style>

<script>
  import {
    loadBookmarks,
    removeBookmark,
    clearBookmarks,
    type Bookmark,
  } from "../../../../lib/bookmarks";

  const listEl = document.querySelector<HTMLOListElement>(
    "[data-bookmark-list]",
  );
  const emptyEl = document.querySelector<HTMLElement>("[data-bookmark-empty]");
  const clearBtn = document.querySelector<HTMLButtonElement>(
    "[data-bookmark-clear]",
  );
  const removeLabel = emptyEl?.dataset.removeLabel ?? "Remove";

  function fmtDate(ms: number): string {
    try {
      return new Date(ms).toLocaleDateString();
    } catch {
      return "";
    }
  }

  function render(): void {
    if (!listEl || !emptyEl) return;
    const items = loadBookmarks().sort((a, b) => b.savedAt - a.savedAt);
    listEl.innerHTML = "";

    if (items.length === 0) {
      emptyEl.hidden = false;
      if (clearBtn) clearBtn.hidden = true;
      return;
    }
    emptyEl.hidden = true;
    if (clearBtn) clearBtn.hidden = false;

    for (const b of items) {
      listEl.append(renderItem(b));
    }
  }

  function renderItem(b: Bookmark): HTMLLIElement {
    const li = document.createElement("li");

    const row = document.createElement("div");
    row.className = "bookmark-row";

    const link = document.createElement("a");
    link.className = "bookmark-title";
    link.href = b.href;
    link.textContent = b.title;

    const remove = document.createElement("button");
    remove.type = "button";
    remove.className = "bookmark-remove";
    remove.textContent = removeLabel;
    remove.addEventListener("click", () => {
      removeBookmark(b.articleId);
      render();
    });

    row.append(link, remove);

    const meta = document.createElement("p");
    meta.className = "bookmark-meta";
    meta.textContent = [b.subject, b.category, fmtDate(b.savedAt)]
      .filter(Boolean)
      .join(" ・ ");

    li.append(row, meta);

    if (b.summary) {
      const summary = document.createElement("p");
      summary.className = "bookmark-summary";
      summary.textContent = b.summary;
      li.append(summary);
    }
    return li;
  }

  clearBtn?.addEventListener("click", () => {
    clearBookmarks();
    render();
  });

  render();
</script>
