---
import AtlasLayout from "../../../../layouts/AtlasLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import { atlasPath } from "../../../../lib/site";
import { t, LOCALES, type Locale } from "../../../../lib/i18n";
import memberData from "../../../../data/atlas-members.json";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const members = memberData.members.map((member) => ({
  ...member,
  displayRole:
    member.role === "代表"
      ? locale === "ja"
        ? "代表"
        : "Representative"
      : member.role.replace("学習サイト「アトラス」運営", "").trim(),
}));
const importedAt = new Date(memberData.importedAt);
const alternates = LOCALES.map((l) => ({
  hreflang: l,
  href: new URL(atlasPath(l, "team"), Astro.site).href,
}));
---

<AtlasLayout
  locale={locale}
  title={locale === "ja" ? "運営紹介" : "Team"}
  description={
    locale === "ja"
      ? "学習サイト「アトラス」の運営メンバーと担当分野を紹介します。"
      : "Meet the students who edit and maintain the Atlas learning site."
  }
  alternates={alternates}
>
  <div class="container team-page">
    <Breadcrumb
      items={[
        { label: t(locale, "breadcrumbHome"), href: atlasPath(locale) },
        { label: locale === "ja" ? "運営紹介" : "Team" },
      ]}
    />

    <header class="page-header">
      <div>
        <h1>{locale === "ja" ? "運営紹介" : "Team"}</h1>
        <p>
          {
            locale === "ja"
              ? "アトラスは、中学生から大学院生まで、異なる分野を学ぶメンバーによって編集・運営されています。記事執筆のほか、翻訳、ページデザイン、開発も分担しています。"
              : "Atlas is edited by students from secondary school through graduate school. Members contribute subject articles, translations, page design, and development."
          }
        </p>
      </div>
      <dl class="team-summary">
        <div>
          <dt>{locale === "ja" ? "掲載人数" : "Members listed"}</dt>
          <dd>{members.length}{locale === "ja" ? "名" : ""}</dd>
        </div>
        <div>
          <dt>{locale === "ja" ? "情報取得日" : "Imported"}</dt>
          <dd>
            <time datetime={memberData.importedAt}>
              {importedAt.toLocaleDateString(locale === "ja" ? "ja-JP" : "en-US")}
            </time>
          </dd>
        </div>
      </dl>
    </header>

    <div class="directory-tools">
      <label for="member-filter">
        {locale === "ja" ? "名前・所属・担当で絞り込む" : "Filter by name, affiliation, or role"}
      </label>
      <input
        id="member-filter"
        type="search"
        data-member-filter
        placeholder={locale === "ja" ? "例：数学、物理、翻訳" : "e.g. mathematics, translation"}
        autocomplete="off"
      />
      <p aria-live="polite" data-member-count>
        {locale === "ja" ? `${members.length}名を表示` : `Showing ${members.length} members`}
      </p>
    </div>

    <ul class="member-list" data-member-list>
      {
        members.map((member) => (
          <li
            data-member
            data-search={`${member.name} ${member.affiliation} ${member.role} ${member.bio}`.toLowerCase()}
          >
            <div class="member-heading">
              <h2>{member.name}</h2>
              <p class="member-role">{member.displayRole}</p>
            </div>
            <p class="member-affiliation">{member.affiliation}</p>
            {member.bio && (
              <div class="member-bio">
                <h3 class="member-bio-label">
                  {locale === "ja" ? "自己紹介" : "Profile (Japanese)"}
                </h3>
                <p>{member.bio}</p>
              </div>
            )}
          </li>
        ))
      }
    </ul>

    <p class="source-note">
      {
        locale === "ja"
          ? "所属・担当・自己紹介は、現行の公開ページから移植しています。所属の先頭に「*」がある場合は2025年3月以前、ない場合は2025年4月以降の情報です。"
          : "Names, affiliations, roles, and profiles are preserved from the currently published page. Entries marked with an asterisk predate April 2025; unmarked affiliations are from April 2025 or later."
      }
      <a href={memberData.source} rel="noopener noreferrer" target="_blank">
        {locale === "ja" ? "移植元を見る" : "View the source"}
      </a>
    </p>
  </div>
</AtlasLayout>

<script>
  const filter = document.querySelector<HTMLInputElement>("[data-member-filter]");
  const rows = [...document.querySelectorAll<HTMLElement>("[data-member]")];
  const count = document.querySelector<HTMLElement>("[data-member-count]");

  filter?.addEventListener("input", () => {
    const query = filter.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach((row) => {
      const matches = !query || (row.dataset.search ?? "").includes(query);
      row.hidden = !matches;
      if (matches) visible += 1;
    });
    if (count) {
      count.textContent = document.documentElement.lang === "ja"
        ? `${visible}名を表示`
        : `Showing ${visible} members`;
    }
  });
</script>

<style>
  .team-page {
    max-width: 70rem;
  }
  .page-header {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(14rem, 0.6fr);
    gap: clamp(2rem, 6vw, 5rem);
    margin: var(--space-4) 0 var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-default);
  }
  .page-header h1 {
    margin-top: 0;
  }
  .page-header p {
    max-width: 43rem;
  }
  .team-summary {
    margin: 0;
    border-top: 3px solid var(--accent-primary);
  }
  .team-summary div {
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--border-default);
  }
  .team-summary dt {
    color: var(--text-secondary);
    font-size: calc(0.82rem * var(--text-scale));
  }
  .team-summary dd {
    margin: 0;
    font-weight: 650;
  }
  .directory-tools {
    display: grid;
    grid-template-columns: minmax(14rem, 22rem) auto;
    align-items: end;
    gap: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
  }
  .directory-tools label {
    grid-column: 1 / -1;
  }
  .directory-tools input {
    width: 100%;
  }
  .directory-tools p {
    margin: 0;
    color: var(--text-secondary);
  }
  .member-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: var(--space-5);
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 2px solid var(--accent-primary);
  }
  .member-list > li {
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--border-default);
  }
  .member-list > li[hidden] {
    display: none;
  }
  .member-heading {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .member-heading h2 {
    margin: 0;
    font-size: calc(1.08rem * var(--text-scale));
  }
  .member-role,
  .member-affiliation {
    margin: 0;
  }
  .member-role {
    max-width: 16rem;
    color: var(--accent-primary);
    text-align: right;
    font-size: calc(0.82rem * var(--text-scale));
  }
  .member-affiliation {
    margin-top: var(--space-1);
    color: var(--text-secondary);
    font-size: calc(0.88rem * var(--text-scale));
  }
  .member-list details {
    margin-top: var(--space-2);
    font-size: calc(0.88rem * var(--text-scale));
  }
  .member-bio {
    margin-top: var(--space-2);
    font-size: calc(0.88rem * var(--text-scale));
  }
  .member-bio-label {
    margin: 0 0 var(--space-1);
    font-size: calc(0.82rem * var(--text-scale));
    color: var(--text-secondary);
  }
  .member-bio p {
    margin: 0;
  }
  .member-list details summary {
    padding-inline: 0;
  }
  .member-list details .details-body {
    margin: 0;
    padding-inline: 0;
    color: var(--text-secondary);
  }
  .source-note {
    margin-top: var(--space-4);
    color: var(--text-secondary);
    font-size: calc(0.85rem * var(--text-scale));
  }
  .source-note a {
    margin-left: var(--space-2);
  }
  @media (max-width: 767px) {
    .page-header,
    .member-list {
      grid-template-columns: 1fr;
    }
    .directory-tools {
      grid-template-columns: 1fr;
    }
    .directory-tools label {
      grid-column: auto;
    }
    .member-heading {
      display: block;
    }
    .member-role {
      margin-top: var(--space-1);
      max-width: none;
      text-align: left;
    }
  }
</style>
