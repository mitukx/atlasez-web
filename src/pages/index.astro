---
import OrgLayout from "../layouts/OrgLayout.astro";
import { getCollection } from "astro:content";
import { withBase, ORG, formatDate } from "../lib/site";

const news = (await getCollection("news", (n) => n.data.status === "published"))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
const projects = (await getCollection("projects"))
  .filter((p) => p.data.status !== "archived")
  .sort((a, b) => a.data.order - b.data.order);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "Atlasez",
  url: Astro.site?.href,
  email: ORG.email,
  slogan: ORG.philosophy,
};
---

<OrgLayout
  title="ホーム"
  description="Atlasezは「未来の学びを創る。学びで未来を創る。」を理念に、学習サイト「アトラス」などを運営する学生団体です。"
  structuredData={structuredData}
>
  <div class="container">
    <section class="intro" aria-labelledby="intro-heading">
      <div class="intro-main">
        <p class="eyebrow">STUDENT COLLECTIVE / SINCE 2022</p>
        <h1 id="intro-heading">学びをつくる学生団体、Atlasez。</h1>
        <p class="intro-copy">
          学生が中心となり、無料・広告なしの学習サイト「アトラス」を編集しています。
          ゼミの運営基盤や対話イベントも含め、学ぶ人同士が知識を持ち寄れる場所をつくります。
        </p>
        <p class="intro-actions">
          <a class="button" href={withBase("/about/")}>団体について読む</a>
          <a href={withBase("/join/")}>運営に参加する</a>
          <a href={withBase("/contact/")}>連絡する</a>
        </p>
      </div>
      <aside class="statement" aria-label="Atlasezの理念">
        <p class="side-label">STATEMENT</p>
        <p>{ORG.philosophy}</p>
        <p class="statement-note">
          学習コンテンツを一方的に届けるのではなく、学生自身が編集・運営に関わることを重視しています。
        </p>
      </aside>
    </section>

    <div class="home-columns">
      <section aria-labelledby="projects-heading">
        <header class="section-heading">
          <span>01</span>
          <div>
            <p>PROJECT INDEX</p>
            <h2 id="projects-heading">進行中の活動</h2>
          </div>
        </header>
        <ol class="project-index">
          {
            projects.map((p, index) => (
              <li>
                <span class="item-no">{String(index + 1).padStart(2, "0")}</span>
                <div>
                  <h3>
                    <a href={withBase(`/projects/${p.data.slug}/`)}>{p.data.name}</a>
                  </h3>
                  <p>{p.data.shortDescription}</p>
                </div>
                <span class="status-text">
                  {p.data.status === "active" ? "活動中" : "準備中"}
                </span>
              </li>
            ))
          }
        </ol>
        <p class="index-link"><a href={withBase("/projects/")}>すべての活動を見る</a></p>
      </section>

      <section class="news-panel" aria-labelledby="news-heading">
        <header class="section-heading compact">
          <span>02</span>
          <div>
            <p>FIELD NOTES</p>
            <h2 id="news-heading">お知らせ</h2>
          </div>
        </header>
        <ul class="news-list">
          {
            news.map((n) => (
              <li>
                <time datetime={n.data.date.toISOString().slice(0, 10)}>
                  {formatDate(n.data.date)}
                </time>
                <a href={withBase(`/news/${n.id.replace(/\.md$/, "")}/`)}>
                  {n.data.title}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="index-link"><a href={withBase("/news/")}>お知らせ一覧</a></p>
      </section>
    </div>
  </div>
</OrgLayout>

<style>
  .intro {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(15rem, 0.8fr);
    gap: clamp(2rem, 8vw, 7rem);
    padding-block: clamp(2rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--border-default);
  }
  .eyebrow,
  .side-label,
  .section-heading p {
    margin: 0 0 var(--space-2);
    font-family: var(--font-mono);
    font-size: calc(0.72rem * var(--text-scale));
    letter-spacing: 0.09em;
    color: var(--accent-primary);
  }
  .intro h1 {
    max-width: 17em;
    margin: 0 0 var(--space-4);
  }
  .intro-copy {
    max-width: 38rem;
    margin: 0;
    font-size: calc(1.08rem * var(--text-scale));
  }
  .intro-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    align-items: center;
    margin-top: var(--space-4);
  }
  .statement {
    border-left: 2px solid var(--accent-primary);
    padding-left: var(--space-3);
    align-self: end;
  }
  .statement > p:nth-child(2) {
    font-weight: 650;
    font-size: calc(1.08rem * var(--text-scale));
  }
  .statement-note {
    color: var(--text-secondary);
    font-size: calc(0.88rem * var(--text-scale));
  }
  .home-columns {
    display: grid;
    grid-template-columns: minmax(0, 1.8fr) minmax(17rem, 0.75fr);
    gap: clamp(2rem, 7vw, 6rem);
    padding-block: var(--space-6);
  }
  .section-heading {
    display: grid;
    grid-template-columns: 2.5rem 1fr;
    gap: var(--space-3);
    align-items: start;
    padding-top: var(--space-2);
    border-top: 2px solid var(--accent-primary);
  }
  .section-heading > span {
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: calc(0.75rem * var(--text-scale));
  }
  .section-heading h2 {
    margin: 0;
  }
  .project-index {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
  }
  .project-index li {
    display: grid;
    grid-template-columns: 2.5rem minmax(0, 1fr) 4.5rem;
    gap: var(--space-3);
    padding-block: var(--space-3);
    border-top: 1px solid var(--border-default);
  }
  .project-index h3,
  .project-index p {
    margin: 0;
  }
  .project-index p {
    color: var(--text-secondary);
    margin-top: var(--space-1);
  }
  .item-no,
  .status-text {
    font-family: var(--font-mono);
    font-size: calc(0.75rem * var(--text-scale));
    color: var(--text-muted);
  }
  .status-text {
    text-align: right;
  }
  .index-link {
    margin-top: var(--space-3);
  }
  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .news-list li {
    display: block;
    padding-block: var(--space-3);
    border-top: 1px solid var(--border-default);
  }
  .news-list time {
    display: block;
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: calc(0.75rem * var(--text-scale));
    margin-bottom: var(--space-1);
  }
  @media (max-width: 767px) {
    .intro,
    .home-columns {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .intro {
      padding-block: var(--space-4);
    }
    .statement {
      max-width: 30rem;
    }
    .project-index li {
      grid-template-columns: 2rem minmax(0, 1fr);
    }
    .status-text {
      grid-column: 2;
      text-align: left;
    }
  }
</style>
